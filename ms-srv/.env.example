# Base path for config/data folders used by homepage, pihole, caddy, homebox, postgres, redis, MSSQL, and portainer.
DataRootPath=.

# Host IP binding used by pihole for DNS ports.
InternalIP=192.168.1.10

# Pi-hole admin password.
WebPassword=replace-with-strong-password

# SA password used by all SQL Server containers: mssql2022, mssql2025, and mssql2025preview.
MSSQL_PASSWORD=ChangeMe!234

# Password for the PostgreSQL container.
POSTGRES_PASSWORD=replace-with-strong-password

# Miniflux: PostgreSQL database name created for the Miniflux app.
MINIFLUX_DB_NAME=miniflux

# Miniflux: PostgreSQL user created for the Miniflux app.
MINIFLUX_DB_USER=miniflux

# Miniflux: PostgreSQL password for the Miniflux database user.
MINIFLUX_DB_PASSWORD=replace-with-strong-password

# Miniflux: initial admin username used on first startup.
MINIFLUX_ADMIN_USERNAME=admin

# Miniflux: initial admin password used on first startup.
MINIFLUX_ADMIN_PASSWORD=replace-with-strong-password

# Cloudflare API token used by the caddy build/runtime for DNS challenge support.
CF_API_TOKEN=

# InstaKindle: Instapaper API key.
INSTAPAPER_KEY=

# InstaKindle: Instapaper API secret.
INSTAPAPER_SECRET=

# InstaKindle: Instapaper account username.
INSTAPAPER_USERNAME=

# InstaKindle: Instapaper account password.
INSTAPAPER_PASSWORD=

# InstaKindle: destination Kindle email address.
KINDLE_EMAIL=

# InstaKindle: SMTP server host for outbound mail delivery.
SMTP_HOST=

# InstaKindle: SMTP server port.
SMTP_PORT=587

# InstaKindle: SMTP username.
SMTP_USERNAME=

# InstaKindle: SMTP password.
SMTP_PASSWORD=

# InstaKindle: sender email address.
SENDER_EMAIL=

# InstaKindle: polling interval in seconds.
POLL_INTERVAL=900

# InstaKindle: application log level.
LOG_LEVEL=info
